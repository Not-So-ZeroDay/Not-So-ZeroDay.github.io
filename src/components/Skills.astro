---
const skillCategories = [
  {
    label: 'Offensive Security',
    icon: '⚔️',
    skills: [
      'Penetration Testing',
      'Red Team Operations',
      'Exploit Development',
      'Privilege Escalation',
      'Social Engineering',
      'Post-Exploitation',
    ],
  },
  {
    label: 'Web Application Security',
    icon: '🌐',
    skills: [
      'OWASP Top 10',
      'SQL Injection',
      'XSS / CSRF',
      'SSRF / XXE',
      'Authentication Bypass',
      'API Security',
    ],
  },
  {
    label: 'Network Security',
    icon: '🔌',
    skills: [
      'Network Reconnaissance',
      'Man-in-the-Middle',
      'ARP / DNS Spoofing',
      'Firewall Evasion',
      'VPN Analysis',
      'Packet Analysis (Wireshark)',
    ],
  },
  {
    label: 'Tools & Platforms',
    icon: '🛠️',
    skills: [
      'Metasploit Framework',
      'Burp Suite Pro',
      'Nmap / Masscan',
      'Cobalt Strike',
      'BloodHound / SharpHound',
      'Impacket / CrackMapExec',
    ],
  },
  {
    label: 'Languages & Scripting',
    icon: '💻',
    skills: [
      'Python (Tooling)',
      'C++ (Security Tooling)',
      'Bash/ZSH (Linux)',
      'PowerShell (Windows)',
      'JavaScript (Web)',
    ],
  },
  {
    label: 'Forensics & RE',
    icon: '🔍',
    skills: [
      'Reverse Engineering',
      'Malware Analysis',
      'Binary Exploitation',
      'Ghidra / IDA Pro',
      'GDB / pwndbg',
      'Digital Forensics',
    ],
  },
];
---

<section class="section section-alt" id="skills">
  <div class="container">
    <p class="section-label mono text-cyan">// 02. skills</p>
    <h2 class="section-heading">Technical <span class="accent">Arsenal</span></h2>
    <div class="cyan-divider"></div>
    <p class="section-subheading">
      Tools, techniques, and knowledge domains I operate with daily.
    </p>

    <div class="skills-grid">
      {skillCategories.map((cat) => (
        <div class="skill-card card">
          <div class="skill-card-header">
            <span class="skill-icon" aria-hidden="true">{cat.icon}</span>
            <h3 class="skill-category-title">{cat.label}</h3>
          </div>
          <ul class="skill-list">
            {cat.skills.map((skill) => (
              <li class="skill-item">
                <span class="skill-bullet text-cyan" aria-hidden="true">›</span>
                {skill}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-label {
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
    opacity: 0.8;
    max-width: none;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .skill-card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.875rem;
    border-bottom: 1px solid var(--color-border);
  }

  .skill-icon {
    font-size: 1.2rem;
    line-height: 1;
  }

  .skill-category-title {
    font-size: 0.95rem;
    font-family: var(--font-mono);
    color: var(--color-white);
  }

  .skill-list {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .skill-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--color-white-dim);
    transition: var(--transition);
  }

  .skill-item:hover {
    color: var(--color-white);
  }

  .skill-bullet {
    font-size: 1rem;
    font-weight: 700;
    line-height: 1;
    flex-shrink: 0;
  }
</style>
