---
const ctfWriteups = [
  {
    event: 'HTB Cyber Apocalypse 2024',
    category: 'Web',
    challenge: 'LockTalk',
    difficulty: 'Hard',
    points: 500,
    summary:
      'JWT algorithm confusion attack combined with SSRF to achieve RCE on the backend Flask server. Leveraged HS256/RS256 confusion to forge admin tokens.',
    tags: ['JWT', 'SSRF', 'RCE', 'Python'],
    writeup: '/blog/htb-locktalk-writeup',
  },
  {
    event: 'PicoCTF 2024',
    category: 'Binary Exploitation',
    challenge: 'heap3',
    difficulty: 'Medium',
    points: 300,
    summary:
      'Heap overflow vulnerability in a custom allocator. Exploited tcache poisoning to achieve arbitrary write and pop a shell via got.plt overwrite.',
    tags: ['Heap', 'Tcache', 'pwn', 'C'],
    writeup: '/blog/picoctf-heap3',
  },
  {
    event: 'DEFCON CTF Quals 2024',
    category: 'Crypto',
    challenge: 'k-smallest',
    difficulty: 'Hard',
    points: 400,
    summary:
      'Lattice-based attack against a custom DSA variant with biased nonces. Used LLL reduction to recover the private key from a small number of signatures.',
    tags: ['Lattice', 'LLL', 'DSA', 'SageMath'],
    writeup: '/blog/defcon-k-smallest',
  },
  {
    event: 'HackTheBox — Machines',
    category: 'Active Directory',
    challenge: 'Rebound',
    difficulty: 'Insane',
    points: null,
    summary:
      'Full AD domain compromise via Kerberoasting → cross-forest trust abuse → shadow credentials attack to achieve DA on a multi-domain environment.',
    tags: ['Active Directory', 'Kerberos', 'Shadow Creds', 'Windows'],
    writeup: '/blog/htb-rebound',
  },
  {
    event: 'Google CTF 2024',
    category: 'Web',
    challenge: 'gradebook',
    difficulty: 'Medium',
    points: 200,
    summary:
      'Prototype pollution in a Node.js app leading to RCE via the vm2 sandbox escape. Chained with a deserialization gadget for persistent access.',
    tags: ['Proto Pollution', 'Node.js', 'RCE', 'JavaScript'],
    writeup: '/blog/google-ctf-gradebook',
  },
  {
    event: 'HTB Sherlock — Forensics',
    category: 'Forensics',
    challenge: 'Logjammer',
    difficulty: 'Easy',
    points: null,
    summary:
      'Windows event log forensics. Traced lateral movement through WinRM, identified the initial access vector via 4624/4625 logon events, and recovered attacker TTPs.',
    tags: ['DFIR', 'Windows', 'Event Logs', 'Splunk'],
    writeup: '/blog/htb-logjammer',
  },
];

const difficultyColor: Record<string, string> = {
  Easy:   '#3fb950',
  Medium: '#e3b341',
  Hard:   '#f78166',
  Insane: '#a371f7',
};
---

<section class="section section-alt" id="ctf">
  <div class="container">
    <p class="section-label mono text-cyan">// 05. ctf &amp; research</p>
    <h2 class="section-heading">CTF <span class="accent">Writeups</span></h2>
    <div class="cyan-divider"></div>
    <p class="section-subheading">
      Selected challenge writeups and security research from competitions and independent work.
    </p>

    <div class="ctf-list">
      {ctfWriteups.map((item) => (
        <a href={item.writeup} class="ctf-card card">
          <div class="ctf-meta">
            <span class="ctf-event mono">{item.event}</span>
            <span
              class="ctf-difficulty mono"
              style={`color: ${difficultyColor[item.difficulty]}`}
            >
              {item.difficulty}
            </span>
          </div>

          <div class="ctf-body">
            <div class="ctf-header-row">
              <h3 class="ctf-title">{item.challenge}</h3>
              <span class="ctf-category tag">{item.category}</span>
            </div>
            <p class="ctf-summary">{item.summary}</p>
            <div class="tag-row">
              {item.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
          </div>

          <div class="ctf-arrow" aria-hidden="true">→</div>
        </a>
      ))}
    </div>

    <div class="text-center" style="margin-top: 3rem;">
      <a href="/blog" class="btn btn-outline">All Writeups →</a>
    </div>
  </div>
</section>

<style>
  .section-label {
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
    opacity: 0.8;
    max-width: none;
  }

  .ctf-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .ctf-card {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0 1.5rem;
    align-items: center;
    text-decoration: none;
    color: inherit;
  }

  .ctf-card:hover {
    color: inherit;
  }

  .ctf-meta {
    grid-column: 1;
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .ctf-event {
    font-size: 0.75rem;
    color: var(--color-white-muted);
    letter-spacing: 0.04em;
  }

  .ctf-difficulty {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .ctf-body {
    grid-column: 1;
  }

  .ctf-header-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }

  .ctf-title {
    font-size: 1rem;
    color: var(--color-white);
  }

  .ctf-category {
    font-size: 0.7rem;
  }

  .ctf-summary {
    font-size: 0.875rem;
    color: var(--color-white-dim);
    max-width: 70ch;
    line-height: 1.65;
    margin-bottom: 0;
  }

  .ctf-arrow {
    grid-column: 2;
    grid-row: 1 / 4;
    font-family: var(--font-mono);
    color: var(--color-cyan);
    font-size: 1.1rem;
    opacity: 0;
    transition: var(--transition);
    padding-left: 1rem;
    align-self: center;
  }

  .ctf-card:hover .ctf-arrow {
    opacity: 1;
    transform: translateX(4px);
  }

  @media (max-width: 600px) {
    .ctf-card {
      grid-template-columns: 1fr;
    }

    .ctf-arrow {
      display: none;
    }
  }
</style>
