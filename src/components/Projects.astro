---
const projects = [
  {
    title: 'Integrity Guardian',
    description:
      'File integrity monitoring system that detects unauthorized changes to critical system files using cryptographic hashing. Provides real-time alerts and audit trails for incident response.',
    tags: ['Python', 'Security', 'Monitoring', 'Cryptography'],
    github: 'https://github.com/Not-So-ZeroDay/integrity-guardian',
    demo: null,
    status: 'active',
  },
  {
    title: 'AutoPwn Framework',
    description:
      'Modular automated exploitation framework written in Python. Supports plugin-based architecture for custom exploit modules, post-exploitation automation, and report generation.',
    tags: ['Python', 'Exploitation', 'Automation', 'Open Source'],
    github: 'https://github.com/Not-So-ZeroDay/autopwn',
    demo: null,
    status: 'active',
  },
  {
    title: 'WebRecon Toolkit',
    description:
      'Comprehensive web application reconnaissance suite combining passive OSINT, active scanning, and vulnerability fingerprinting into a single CLI tool.',
    tags: ['Python', 'OSINT', 'Web Security', 'CLI'],
    github: 'https://github.com/Not-So-ZeroDay/webrecon',
    demo: null,
    status: 'active',
  },
  {
    title: 'AD BloodHound Automation',
    description:
      'Scripts and playbooks to automate Active Directory enumeration, BloodHound data collection, and attack path identification during red team assessments.',
    tags: ['PowerShell', 'Active Directory', 'Red Team', 'BloodHound'],
    github: 'https://github.com/Not-So-ZeroDay/ad-bloodhound-auto',
    demo: null,
    status: 'active',
  },
  {
    title: 'CVE-2024-XXXX PoC',
    description:
      'Proof-of-concept exploit for a critical authentication bypass vulnerability discovered through independent research. Responsibly disclosed and patched.',
    tags: ['CVE', 'Exploit', 'Responsible Disclosure', 'C'],
    github: 'https://github.com/Not-So-ZeroDay/cve-poc',
    demo: null,
    status: 'archived',
  },
  {
    title: 'Phishing Infrastructure Toolkit',
    description:
      'Red team phishing campaign setup automation: GoPhish deployment, domain categorization bypass, email template generation, and tracking dashboard.',
    tags: ['Go', 'Red Team', 'Phishing', 'Docker'],
    github: 'https://github.com/Not-So-ZeroDay/phish-infra',
    demo: null,
    status: 'active',
  },
  {
    title: 'CTF Solver Toolkit',
    description:
      'Collection of purpose-built scripts for rapid CTF challenge solving: crypto solvers, binary patchers, steg extractors, and web exploit templates.',
    tags: ['Python', 'CTF', 'Cryptography', 'Forensics'],
    github: 'https://github.com/Not-So-ZeroDay/ctf-toolkit',
    demo: null,
    status: 'active',
  },
];
---

<section class="section" id="projects">
  <div class="container">
    <p class="section-label mono text-cyan">// 03. projects</p>
    <h2 class="section-heading">Featured <span class="accent">Projects</span></h2>
    <div class="cyan-divider"></div>
    <p class="section-subheading">
      Open-source tools and research I've built and published.
    </p>

    <div class="projects-grid">
      {projects.map((project) => (
        <article class="project-card card">
          <div class="project-header">
            <svg class="project-folder" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
            </svg>
            <div class="project-links">
              {project.github && (
                <a href={project.github} target="_blank" rel="noopener noreferrer" aria-label={`${project.title} on GitHub`} class="project-link">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
                  </svg>
                </a>
              )}
              {project.demo && (
                <a href={project.demo} target="_blank" rel="noopener noreferrer" aria-label={`${project.title} live demo`} class="project-link">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                  </svg>
                </a>
              )}
            </div>
          </div>

          <h3 class="project-title">{project.title}</h3>
          <p class="project-desc">{project.description}</p>

          <div class="tag-row">
            {project.tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>

          {project.status === 'archived' && (
            <span class="project-status">archived</span>
          )}
        </article>
      ))}
    </div>

    <div class="projects-more text-center">
      <a
        href="https://github.com/Not-So-ZeroDay"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-outline"
      >
        View all on GitHub →
      </a>
    </div>
  </div>
</section>

<style>
  .section-label {
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
    opacity: 0.8;
    max-width: none;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.1rem;
  }

  .project-folder {
    color: var(--color-cyan);
  }

  .project-links {
    display: flex;
    gap: 0.75rem;
  }

  .project-link {
    color: var(--color-white-muted);
    transition: var(--transition);
  }

  .project-link:hover {
    color: var(--color-cyan);
    text-shadow: none;
  }

  .project-title {
    font-size: 1rem;
    margin-bottom: 0.6rem;
    color: var(--color-white);
  }

  .project-desc {
    font-size: 0.875rem;
    color: var(--color-white-dim);
    flex: 1;
    line-height: 1.65;
    max-width: none;
  }

  .project-status {
    display: inline-block;
    margin-top: 1rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-white-muted);
    border: 1px solid var(--color-border);
    padding: 0.1rem 0.5rem;
    border-radius: 2px;
    letter-spacing: 0.06em;
  }

  .projects-more {
    margin-top: 3rem;
  }
</style>
