---
---

<section class="section" id="contact">
  <div class="container">
    <p class="section-label mono">// 06. contact</p>
    <h2 class="section-heading">Get In <span class="accent">Touch</span></h2>
    <div class="cyan-divider"></div>

    <div class="contact-grid">
      <div class="contact-text">
        <p>
          Whether you're looking for a pentester, a collaborator, or to discuss a responsible disclosure — my inbox is open. I respond to all serious enquiries.
        </p>
        <br />
        <p>
          For vulnerability reports, please use the PGP-encrypted channel or
          the secure contact form. For general enquiries, any channel works.
        </p>

        <div class="contact-methods">
          <a href="mailto:not_zeroz-day@proton.me" class="contact-method">
            <span class="method-icon text-cyan" aria-hidden="true">✉</span>
            <div>
              <span class="method-label mono">Email</span>
              <span class="method-value">not_zeroz-day@proton.me</span>
            </div>
          </a>
          <a href="https://github.com/Not-So-ZeroDay" target="_blank" rel="noopener noreferrer" class="contact-method">
            <span class="method-icon text-cyan" aria-hidden="true">⌥</span>
            <div>
              <span class="method-label mono">GitHub</span>
              <span class="method-value">Not-So-ZeroDay</span>
            </div>
          </a>
        </div>
      </div>

      <!-- Contact form -->
      <form class="contact-form card" name="contact" method="POST" data-netlify="true" novalidate>
        <input type="hidden" name="form-name" value="contact" />

        <div class="form-group">
          <label for="name" class="form-label mono">name</label>
          <input
            type="text"
            id="name"
            name="name"
            class="form-input"
            placeholder="your_handle"
            required
          />
        </div>

        <div class="form-group">
          <label for="email" class="form-label mono">email</label>
          <input
            type="email"
            id="email"
            name="email"
            class="form-input"
            placeholder="you@example.com"
            required
          />
        </div>

        <div class="form-group">
          <label for="subject" class="form-label mono">subject</label>
          <input
            type="text"
            id="subject"
            name="subject"
            class="form-input"
            placeholder="Pentest engagement / Research collab / ..."
          />
        </div>

        <div class="form-group">
          <label for="message" class="form-label mono">message</label>
          <textarea
            id="message"
            name="message"
            class="form-input form-textarea"
            placeholder="Hello Not0Day, ..."
            rows="5"
            required
          ></textarea>
        </div>

        <button type="submit" class="btn btn-primary form-submit">
          Send Message
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
          </svg>
        </button>
      </form>
    </div>
  </div>
</section>

<style>
  .section-label {
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
    opacity: 0.8;
    max-width: none;
    color: var(--color-white-muted);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .contact-text p {
    color: var(--color-white-dim);
    font-size: 0.95rem;
  }

  /* Contact methods */
  .contact-methods {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 2rem;
  }

  .contact-method {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: var(--color-white-dim);
    transition: var(--transition);
    text-decoration: none;
  }

  .contact-method:hover {
    color: var(--color-cyan);
    text-shadow: none;
  }

  .contact-method:hover .method-value {
    color: var(--color-cyan);
  }

  .method-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--color-cyan-glow);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 700;
    flex-shrink: 0;
    transition: var(--transition);
  }

  .contact-method:hover .method-icon {
    border-color: var(--color-cyan);
    box-shadow: var(--glow-cyan-sm);
  }

  .method-label {
    display: block;
    font-size: 0.7rem;
    color: var(--color-white-muted);
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  .method-value {
    display: block;
    font-size: 0.9rem;
    color: var(--color-white-dim);
    transition: var(--transition);
  }

  /* Form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-label {
    font-size: 0.75rem;
    color: var(--color-white);
    letter-spacing: 0.06em;
    text-transform: lowercase;
  }

  .form-input {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.65rem 0.875rem;
    color: var(--color-white);
    font-family: var(--font-mono);
    font-size: 0.88rem;
    outline: none;
    transition: var(--transition);
    width: 100%;
  }

  .form-input::placeholder {
    color: var(--color-white-muted);
  }

  .form-input:focus {
    border-color: var(--color-cyan);
    box-shadow: 0 0 0 2px rgba(0, 255, 255, 0.1);
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-submit {
    width: 100%;
    justify-content: center;
  }

  @media (max-width: 800px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
