---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Not Found | Not0Day">
  <div class="notfound">
    <div class="container notfound-inner">
      <p class="nf-code text-cyan mono">404</p>
      <h1 class="nf-title">Page Not Found</h1>
      <p class="nf-desc">
        <span class="mono text-cyan">~/</span> — This directory does not exist.
        The resource may have been moved or you've wandered outside the map.
      </p>
      <div class="terminal-404" aria-hidden="true">
        <span class="mono text-cyan">not0day@kali</span><span class="mono" style="color:var(--color-white-muted)">:~$ </span>
        <span class="mono">cat /var/www/this-page</span><br />
        <span class="mono" style="color:#f78166;">cat: /var/www/this-page: No such file or directory</span>
      </div>
      <a href="/" class="btn btn-primary">cd ~/ (Go Home)</a>
    </div>
  </div>
</Layout>

<style>
  .notfound {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .notfound-inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .nf-code {
    font-family: var(--font-mono);
    font-size: clamp(4rem, 12vw, 8rem);
    font-weight: 700;
    text-shadow: var(--glow-cyan);
    max-width: none;
    line-height: 1;
  }

  .nf-title {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    color: var(--color-white);
  }

  .nf-desc {
    max-width: 45ch;
    color: var(--color-white-dim);
    text-align: center;
  }

  .terminal-404 {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 1rem 1.5rem;
    font-size: 0.85rem;
    text-align: left;
    line-height: 1.8;
  }
</style>
