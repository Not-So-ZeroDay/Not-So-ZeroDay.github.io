---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="HTB Writeups | Not0Day" description="HackTheBox writeups and penetration testing documentation.">
  <section class="section" id="htb">
    <div class="container">
      <a href="/" class="back-link mono">← Back to Home</a>
      <p class="section-label mono">// htb writeups</p>
      <h2 class="section-heading">HTB <span class="accent">Writeups</span></h2>
      <div class="cyan-divider"></div>
      <p class="section-subheading">
        HackTheBox learning paths — select a category to explore writeups and research notes.
      </p>

      <div class="lab-grid">
        <a href="/htb/cpts" class="lab-module card">
          <span class="mod-id mono">01</span>
          <h3 class="mod-name">CPTS</h3>
          <div class="mod-footer">
            <span class="mod-status mono">[ ENTER ]</span>
          </div>
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .back-link {
    display: inline-block;
    font-size: 0.8rem;
    color: var(--color-cyan);
    text-decoration: none;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
    transition: var(--transition);
  }

  .back-link:hover {
    color: var(--color-white);
  }

  .section-label {
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
    opacity: 0.8;
    max-width: none;
    color: var(--color-white-muted);
  }

  .lab-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.25rem;
  }

  .lab-module {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem 1.4rem;
    transition: var(--transition);
    text-decoration: none;
  }

  .lab-module:hover {
    background: var(--color-bg-card-hover);
    border-color: var(--color-cyan);
    box-shadow: 0 0 16px rgba(0, 255, 255, 0.2);
    transform: translateY(-3px);
  }

  .mod-id {
    font-size: 0.7rem;
    color: var(--color-cyan);
    letter-spacing: 0.1em;
    transition: var(--transition);
  }

  .mod-name {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-white);
    line-height: 1.4;
    transition: var(--transition);
  }

  .lab-module:hover .mod-name {
    color: var(--color-cyan);
  }

  .mod-footer {
    margin-top: auto;
    padding-top: 0.75rem;
  }

  .mod-status {
    font-size: 0.68rem;
    color: var(--color-white-muted);
    letter-spacing: 0.05em;
    transition: var(--transition);
  }

  .lab-module:hover .mod-status {
    color: var(--color-cyan-dim);
  }

  @media (max-width: 600px) {
    .lab-grid {
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    }
  }
</style>
